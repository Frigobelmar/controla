# DOE Framework — .gitignore

# Arquivos temporários (sempre regeneráveis)
.tmp/
*.tmp

# Variáveis de ambiente (nunca commitar)
.env
.env.local
.env.*.local

# Credenciais OAuth Google
credentials.json
token.json
service_account.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Node
node_modules/
npm-debug.log*

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini
