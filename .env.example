# ============================================================
# DOE Framework — Variáveis de Ambiente
# ============================================================
# INSTRUÇÕES:
#   1. Copie este arquivo para .env
#   2. Preencha os valores reais (sem aspas, a menos que necessário)
#   3. NUNCA commite o arquivo .env
# ============================================================

# --- Projeto ---
PROJECT_NAME=nome-do-projeto
PROJECT_ENV=development   # development | staging | production

# --- Google APIs (se usadas) ---
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json
# GOOGLE_SPREADSHEET_ID=
# GOOGLE_DRIVE_FOLDER_ID=

# --- OpenAI / LLM (se usado) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Banco de Dados ---
# DATABASE_URL=

# --- Outras APIs ---
# Adicione suas chaves aqui seguindo o padrão:
# NOME_DO_SERVICO_API_KEY=
